# ------------------------------------------------------------------
# JanVaani environment variables
# Copy this file to `.env.local` and fill in your values.
# NEVER commit .env.local — it is gitignored.
# ------------------------------------------------------------------

# --- Firebase (client SDK — safe to expose, protected by Firebase rules) ---
# Get these from Firebase Console → Project settings → Your apps → Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Server-side Google Cloud (NEVER prefixed with NEXT_PUBLIC) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI — Claude Haiku 4.5 (Anthropic on Google Cloud) for classification/clustering.
# On Cloud Run this is provided by the attached service account (Application Default Credentials).
VERTEX_ANTHROPIC_MODEL=claude-haiku-4-5@20251001

# Cloud Storage bucket for citizen voice/photo uploads.
UPLOADS_BUCKET=janvaani-uploads

# Speech-to-Text default recognizer region.
SPEECH_TO_TEXT_LOCATION=us-central1
